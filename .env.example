# Telnyx Voice Inbox — Configuration
# Copy this file to .env and fill in your values

# Your Telnyx API key (from portal.telnyx.com → API Keys)
TELNYX_API_KEY=KEYxxxxx

# Storage bucket name (will be created if it doesn't exist)
TELNYX_STORAGE_BUCKET=voice-inbox

# Your personal phone number — calls from this number get the admin menu
OWNER_NUMBER=+1XXXXXXXXXX

# The Telnyx phone number that customers call
PHONE_NUMBER=+1XXXXXXXXXX

# Business name used in the voice greeting
BUSINESS_NAME=Acme Corp
